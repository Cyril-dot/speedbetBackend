# ============================================================
# SpeedBet .env.example — copy to .env and fill in values
# ============================================================

# ── Database ──────────────────────────────────────────────
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/speedbet
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=esselAnthony123$$

# ── JWT ───────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=
JWT_ACCESS_TTL_MINUTES=30
JWT_REFRESH_TTL_DAYS=14

# ── Payments ──────────────────────────────────────────────
PAYSTACK_SECRET_KEY=sk_test_xxx
PAYSTACK_PUBLIC_KEY=pk_test_xxx
PAYSTACK_WEBHOOK_SECRET=xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ── Sports Data ───────────────────────────────────────────
# Leave as "demo" to use built-in demo data (no real API calls)
SPORTDB_API_KEY=demo
SPORTSRC_API_KEY=demo

# ── AI (Mistral) ──────────────────────────────────────────
# Leave as "placeholder" for demo predictions
MISTRAL_API_KEY=placeholder
MISTRAL_MODEL=mistral-large-latest

# ── Platform ──────────────────────────────────────────────
MIN_DEPOSIT_AMOUNT=300
MIN_DEPOSIT_CURRENCY=GHS
ADMIN_COMMISSION_PERCENT=10
REFERRAL_SIGNUP_BONUS=50
PAYOUT_DAY_OF_WEEK=FRIDAY
# Set true to enable demo mode (no real API calls, no real money)
DEMO_MODE=false
FRONTEND_URL=http://localhost:5173

# ── Super Admin ───────────────────────────────────────────
# NEVER expose this path in any frontend UI
# Share only with the operator/developer
SUPER_ADMIN_DIRECT_PATH=/x-control-9f3a2b

# ── VIP ───────────────────────────────────────────────────
VIP_MEMBERSHIP_PRICE=250
VIP_MEMBERSHIP_CURRENCY=GHS
VIP_MEMBERSHIP_DAYS=30
VIP_CASHBACK_MIN_SELECTIONS=10
VIP_CASHBACK_PERCENT=1.00
VIP_CASHBACK_MIN_STAKE=10
VIP_CASHBACK_WEEKLY_CAP=1000

# ── Crash AI Engine ───────────────────────────────────────
CRASH_HIGH_THRESHOLD=10.0
CRASH_EXTREME_THRESHOLD=20.0
CRASH_SCHEDULE_BUFFER=100
CRASH_BATCH_SIZE=50
CRASH_REPLENISH_INTERVAL_HOURS=1
CRASH_ALERT_LOOKAHEAD_ROUNDS=3
CRASH_CARD_STORAGE_PATH=./uploads/crash-cards
CRASH_FALLBACK_SEED=42

# ── Demo Seed Credentials ─────────────────────────────────
# Super Admin: super@speedbet.app / Change!Me.2026
# Admin 1:     admin1@speedbet.app / Change!Me.2026
# Admin 2:     admin2@speedbet.app / Change!Me.2026
# User:        user@speedbet.app   / Change!Me.2026
# VIP User:    vip@speedbet.app    / Change!Me.2026
# IMPORTANT: Change all passwords before going to production
